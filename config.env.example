# daily-digest configuration
#
# Copy this file to $XDG_CONFIG_HOME/daily-digest/config.env
# (defaults to ~/.config/daily-digest/config.env) and edit to suit.
# It is sourced by the daily-digest script as bash, so quote values.

# --- Required ---------------------------------------------------------------

# Absolute path to your Obsidian vault
VAULT="$HOME/vault"

# City for weather (wttr.in resolves names globally)
LOCATION="YOUR CITY"

# Your GitHub username, used for PR searches
GH_USER="your-github-username"

# --- Optional (defaults shown) ---------------------------------------------

# Subdirectory inside the vault for daily notes
# DAILY_SUBDIR="10-Daily"

# Path within the vault to the quotes file (used by "Quote of the day")
# QUOTES_PATH="40-Resources/Quotes.md"

# Directories under which to look for git repositories (scanned 3 levels deep).
# Declared as a bash array. Omit to default to just scanning the vault itself.
REPO_PARENTS=(
    "$HOME/workProjects"
    "$HOME/homeProjects"
    "$VAULT"
)

# News sources for the digest. One entry per line: "Label|RSS_URL".
# Label becomes the "### " subheading under the ## News section. Omit the
# array entirely to leave the News section as a placeholder.
#
# The entries below are a starting point — BBC World, Hacker News, and
# Ars Technica Science are broadly useful; the national/regional/local
# slots are placeholders you should point at publications relevant to
# where you live.
NEWS_FEEDS=(
    "Global|https://feeds.bbci.co.uk/news/world/rss.xml"
    # "National|https://example.com/national/feed"
    # "Regional|https://example.com/regional/feed"
    # "Local|https://example.com/local/feed"
    "Tech|https://hnrss.org/frontpage"
    "Science|https://feeds.arstechnica.com/arstechnica/science"
)

# Max headlines shown per feed (default 5)
# NEWS_LIMIT_PER_FEED=5
