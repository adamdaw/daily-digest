#!/usr/bin/env bash
# daily-digest — morning digest generator for an Obsidian vault
#
# Generates a structured markdown digest into a configured vault, including
# weather, git activity, GitHub PRs, and a rotating quote. Idempotent per
# day; safe to re-run.
#
# Configuration is read from $XDG_CONFIG_HOME/daily-digest/config.env
# (default ~/.config/daily-digest/config.env). Copy config.env.example and
# edit it to suit.

set -euo pipefail

# Ensure cron's minimal PATH finds our tools
export PATH="/usr/local/bin:/usr/bin:/bin:$HOME/.local/bin:$HOME/bin:$PATH"

CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/daily-digest"
CONFIG_FILE="${DAILY_DIGEST_CONFIG:-$CONFIG_DIR/config.env}"

if [[ ! -f "$CONFIG_FILE" ]]; then
    cat >&2 <<EOF
daily-digest: no config at $CONFIG_FILE

Create one by copying the example from the project root:

    mkdir -p "$CONFIG_DIR"
    cp config.env.example "$CONFIG_FILE"
    \$EDITOR "$CONFIG_FILE"

Or point DAILY_DIGEST_CONFIG at a different file.
EOF
    exit 1
fi

# shellcheck disable=SC1090
source "$CONFIG_FILE"

: "${VAULT:?VAULT must be set in $CONFIG_FILE (path to your Obsidian vault)}"
: "${LOCATION:?LOCATION must be set in $CONFIG_FILE (city name for weather)}"
: "${GH_USER:?GH_USER must be set in $CONFIG_FILE (GitHub username)}"
: "${DAILY_SUBDIR:=10-Daily}"
: "${QUOTES_PATH:=40-Resources/Quotes.md}"
: "${TODOS_PATH:=30-Areas/Daily Reading/_pending-acquisitions.md}"

# REPO_PARENTS is expected to be a bash array declared in the config file.
# If it wasn't set, fall back to scanning the vault only.
if ! declare -p REPO_PARENTS >/dev/null 2>&1; then
    REPO_PARENTS=("$VAULT")
fi

DATE="$(date +%Y-%m-%d)"
LONG_DATE="$(date '+%A, %B %-d, %Y')"
DAILY_DIR="$VAULT/$DAILY_SUBDIR"
QUOTES_FILE="$VAULT/$QUOTES_PATH"
TODOS_FILE="$VAULT/$TODOS_PATH"
OUT="$DAILY_DIR/${DATE}.md"

mkdir -p "$DAILY_DIR"

# Idempotency: skip if today's digest already exists and was written today
if [[ -f "$OUT" && "$(date -r "$OUT" +%Y-%m-%d)" == "$DATE" ]]; then
    echo "Digest already present for $DATE; not overwriting." >&2
    exit 0
fi

fetch_weather() {
    local data temp feels desc hi lo attempt plain
    # wttr.in can return a rate-limit banner with HTTP 200, which curl -f
    # can't detect. Require a JSON body and retry before giving up.
    for attempt in 1 2 3; do
        if data=$(curl -fsS --max-time 20 "https://wttr.in/${LOCATION}?format=j1" 2>/dev/null) \
            && [[ "${data:0:1}" == "{" ]]; then
            temp=$(echo "$data" | jq -r '.current_condition[0].temp_C // empty')
            feels=$(echo "$data" | jq -r '.current_condition[0].FeelsLikeC // empty')
            desc=$(echo "$data" | jq -r '.current_condition[0].weatherDesc[0].value // empty')
            hi=$(echo "$data" | jq -r '.weather[0].maxtempC // empty')
            lo=$(echo "$data" | jq -r '.weather[0].mintempC // empty')
            if [[ -n "$temp" && -n "$desc" ]]; then
                echo "**${desc}**, ${temp}°C (feels ${feels}°C) · Today: ${lo}°C → ${hi}°C"
                return
            fi
        fi
        sleep "$((attempt * 3))"
    done
    # Plain-text fallback — lighter endpoint, less prone to throttling.
    if plain=$(curl -fsS --max-time 15 "https://wttr.in/${LOCATION}?format=3" 2>/dev/null) \
        && [[ -n "$plain" && "$plain" != *"Unknown location"* ]]; then
        echo "$plain"
        return
    fi
    echo "_weather unavailable_"
}

fetch_git_activity() {
    local since="24 hours ago"
    local found=0 gitdir repo log
    for parent in "${REPO_PARENTS[@]}"; do
        [[ -d "$parent" ]] || continue
        while IFS= read -r -d '' gitdir; do
            repo=$(dirname "$gitdir")
            log=$(git -C "$repo" log --since="$since" --pretty=format:"- \`$(basename "$repo")\` %h — %s (%an)" 2>/dev/null || true)
            if [[ -n "$log" ]]; then
                echo "$log"
                found=1
            fi
        done < <(find "$parent" -maxdepth 3 -type d -name ".git" -print0 2>/dev/null)
    done
    [[ "$found" == "0" ]] && echo "_no commits in the last 24 hours_"
}

fetch_prs() {
    if ! command -v gh >/dev/null 2>&1; then
        echo "_gh CLI not installed_"
        return
    fi
    if ! gh auth status >/dev/null 2>&1; then
        echo "_gh not authenticated — run \`gh auth login\`_"
        return
    fi

    local authored review
    authored=$(gh search prs --author="$GH_USER" --state=open --limit 10 --json url,title,repository 2>/dev/null || echo "[]")
    review=$(gh search prs --review-requested="$GH_USER" --state=open --limit 10 --json url,title,repository 2>/dev/null || echo "[]")

    echo "**Authored (open):**"
    if [[ "$(echo "$authored" | jq 'length')" == "0" ]]; then
        echo "- _none_"
    else
        echo "$authored" | jq -r '.[] | "- [\(.repository.nameWithOwner) — \(.title)](\(.url))"'
    fi

    echo ""
    echo "**Awaiting your review:**"
    if [[ "$(echo "$review" | jq 'length')" == "0" ]]; then
        echo "- _none_"
    else
        echo "$review" | jq -r '.[] | "- [\(.repository.nameWithOwner) — \(.title)](\(.url))"'
    fi
}

fetch_quote() {
    local resp q a
    # Primary source: zenquotes.io /api/today — one daily quote, stable all day.
    if resp=$(curl -fsS --max-time 10 "https://zenquotes.io/api/today" 2>/dev/null) \
        && [[ "${resp:0:1}" == "[" ]]; then
        q=$(echo "$resp" | jq -r '.[0].q // empty')
        a=$(echo "$resp" | jq -r '.[0].a // empty')
        if [[ -n "$q" ]]; then
            if [[ -n "$a" ]]; then
                echo "\"${q}\" — ${a}"
            else
                echo "\"${q}\""
            fi
            return
        fi
    fi
    # Fallback: rotate through the local quotes file.
    if [[ ! -f "$QUOTES_FILE" ]]; then
        echo "_no quote available_"
        return
    fi
    local count n
    count=$(grep -c "^- " "$QUOTES_FILE" 2>/dev/null || echo 0)
    if [[ "$count" -eq 0 ]]; then
        echo "_no quotes in file yet_"
        return
    fi
    n=$(( (RANDOM % count) + 1 ))
    grep "^- " "$QUOTES_FILE" | sed -n "${n}p" | sed 's/^- //'
}

fetch_todos() {
    if [[ ! -f "$TODOS_FILE" ]]; then
        echo "<!-- no todo file at $TODOS_FILE -->"
        echo "-"
        return
    fi
    # Pull bullet items only ("- ..." or "  - ..."), preserving headers (## ...)
    # so the section structure carries through. Skip code fences and metadata.
    local in_yaml=0 in_code=0
    while IFS= read -r line; do
        case "$line" in
            "---")
                if [[ $in_yaml -eq 0 ]]; then in_yaml=1; else in_yaml=0; fi
                continue
                ;;
            '```'*)
                if [[ $in_code -eq 0 ]]; then in_code=1; else in_code=0; fi
                continue
                ;;
        esac
        [[ $in_yaml -eq 1 || $in_code -eq 1 ]] && continue
        # Surface section headers (## or ###) and bullet items
        case "$line" in
            "## "*|"### "*)
                # Skip the top-level title and the meta sections at the bottom
                case "$line" in
                    "## How to use"*|"# Pending"*) continue ;;
                esac
                echo ""
                echo "$line"
                ;;
            "- "*|"  - "*|"~~- "*)
                echo "$line"
                ;;
        esac
    done < "$TODOS_FILE"
}

fetch_news() {
    if ! declare -p NEWS_FEEDS >/dev/null 2>&1 || [[ ${#NEWS_FEEDS[@]} -eq 0 ]]; then
        echo "<!-- placeholder: set NEWS_FEEDS in $CONFIG_FILE -->"
        return
    fi
    if ! command -v python3 >/dev/null 2>&1; then
        echo "_news unavailable: python3 required to parse RSS_"
        return
    fi

    # RSS/Atom parser. Reads XML from stdin, prints markdown bullets.
    local py_script
    py_script=$(cat <<'PYEOF'
import sys, os, html, re
import xml.etree.ElementTree as ET
limit = int(os.environ.get('LIMIT', '5'))
raw = sys.stdin.read()
try:
    root = ET.fromstring(raw)
except ET.ParseError:
    sys.exit(1)
ns = {'atom': 'http://www.w3.org/2005/Atom'}
items = root.findall('.//item')[:limit]
if not items:
    items = root.findall('.//atom:entry', ns)[:limit]
out = []
for it in items:
    title = it.findtext('title') or it.findtext('atom:title', default='', namespaces=ns) or ''
    link_el = it.find('link')
    if link_el is not None and (link_el.text or '').strip():
        link = link_el.text.strip()
    else:
        link_el = it.find('atom:link', ns)
        link = link_el.get('href', '') if link_el is not None else ''
    title = re.sub(r'\s+', ' ', html.unescape(title).strip())
    link = link.strip()
    if title and link:
        out.append(f'- [{title}]({link})')
print('\n'.join(out))
PYEOF
)

    local limit="${NEWS_LIMIT_PER_FEED:-5}"
    local first=1 entry label url xml parsed
    for entry in "${NEWS_FEEDS[@]}"; do
        label="${entry%%|*}"
        url="${entry#*|}"
        [[ "$first" == "1" ]] || echo ""
        first=0
        echo "### $label"
        if ! xml=$(curl -fsSL --max-time 15 -A "daily-digest/1.0" "$url" 2>/dev/null) || [[ -z "$xml" ]]; then
            echo "- _feed unavailable_"
            continue
        fi
        parsed=$(printf '%s' "$xml" | LIMIT="$limit" python3 -c "$py_script" 2>/dev/null || true)
        if [[ -z "$parsed" ]]; then
            echo "- _feed unavailable_"
        else
            echo "$parsed"
        fi
    done
}

# Render to temp, move atomically so Obsidian never sees a half-written file
TMP=$(mktemp)
trap 'rm -f "$TMP"' EXIT

{
cat <<EOF
---
type: daily
date: ${DATE}
tags: [daily, digest]
generated: $(date -Iseconds)
---

# ${LONG_DATE}

#daily #digest

## Weather · ${LOCATION}

$(fetch_weather)

## Quote of the day

> $(fetch_quote)

## Tasks

$(fetch_todos)

## Calendar

<!-- placeholder: source TBD -->

## Git activity (last 24h)

$(fetch_git_activity)

## GitHub PRs

$(fetch_prs)

## News

$(fetch_news)

## Notes

-
EOF
} > "$TMP"

mv "$TMP" "$OUT"
trap - EXIT
echo "Wrote digest to $OUT"
